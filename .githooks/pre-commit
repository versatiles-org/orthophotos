#!/bin/sh

# Check formatting of staged .ts files
STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.ts$' || true)
if [ -n "$STAGED" ]; then
  echo "Checking formatting..."
  echo "$STAGED" | xargs npx prettier --check 2>&1
  if [ $? -ne 0 ]; then
    echo ""
    echo "Formatting issues found. Run 'npm run format' to fix."
    exit 1
  fi
fi
