{
	"name": "orthophotos",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"build:status": "node --env-file=config.env --import tsx/esm src/status-check.ts",
		"check:remote": "node --env-file=config.env --import tsx/esm src/check-remote.ts",
		"check": "npm run format:check && npm run lint && npm run typecheck && npm run test",
		"docs:graph": "vrt deps-graph --collapse-dir 'src/regions/**/*.ts' | vrt doc-insert README.md '### Dependency Graph'",
		"format:check": "prettier --check .",
		"format": "prettier --log-level warn --write .",
		"lint": "eslint 'src/**/*.ts'",
		"pipeline": "node --env-file=config.env --import tsx/esm src/run.ts",
		"prepare": "git config core.hooksPath .githooks",
		"preview": "node --env-file=config.env --import tsx/esm src/preview.ts",
		"publish:world:local": "node --env-file=config.env --import tsx/esm src/publish-world-local.ts",
		"publish:world": "node --env-file=config.env --import tsx/esm src/publish-world.ts",
		"status": "npm run build:status && open web/index.html",
		"test:coverage": "vitest run --coverage",
		"test": "vitest run",
		"typecheck": "npx tsc --noEmit",
		"upgrade": "vrt deps-upgrade"
	},
	"dependencies": {
		"fast-xml-parser": "^5.8.0",
		"topojson-client": "^3.1.0"
	},
	"engines": {
		"node": ">=22"
	},
	"devDependencies": {
		"@types/geojson": "^7946.0.16",
		"@types/node": "^25.8.0",
		"@types/topojson-client": "^3.1.5",
		"@versatiles/release-tool": "^2.8.0",
		"@vitest/coverage-v8": "^4.1.6",
		"eslint": "^10.4.0",
		"prettier": "^3.8.3",
		"tsx": "^4.22.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3",
		"vitest": "^4.1.6"
	}
}
