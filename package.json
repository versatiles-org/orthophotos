{
	"name": "orthophotos",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"check": "npx tsc --noEmit && vitest run",
		"test": "vitest run",
		"format": "prettier --write 'src/**/*.ts'",
		"server-prepare": "node --env-file=config.env --import tsx/esm src/server-prepare.ts",
		"server-start": "./server.sh",
		"server": "npm run server-prepare && npm run server-start",
		"status-check": "node --env-file=config.env --import tsx/esm src/status-check.ts",
		"run": "node --env-file=config.env --import tsx/esm src/run.ts",
		"upgrade": "npm-check-updates -u && npm install"
	},
	"dependencies": {
		"topojson-client": "^3.1.0",
		"yaml": "^2.7.0"
	},
	"devDependencies": {
		"@types/geojson": "^7946.0.16",
		"@types/node": "^22.0.0",
		"@types/topojson-client": "^3.1.0",
		"prettier": "^3.0.0",
		"tsx": "^4.0.0",
		"typescript": "^5.0.0",
		"npm-check-updates": "^17.0.0",
		"vitest": "^3.0.0"
	}
}
