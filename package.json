{
	"name": "orthophotos",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"check": "npm run format:check && npm run lint && npm run typecheck && npm run test",
		"doc-graph": "vrt deps-graph | vrt doc-insert README.md '### Dependency Graph'",
		"doc": "npm run doc-graph",
		"lint": "eslint 'src/**/*.ts'",
		"format:check": "prettier --check 'src/**/*.ts' 'web/index.{css,js}'",
		"format": "prettier --log-level warn --write 'src/**/*.ts' 'web/index.{css,js}'",
		"run": "node --env-file=config.env --import tsx/esm src/run.ts",
		"preview": "node --env-file=config.env --import tsx/esm src/preview.ts",
		"publish-world": "node --env-file=config.env --import tsx/esm src/publish-world.ts",
		"publish-world-local": "node --env-file=config.env --import tsx/esm src/publish-world-local.ts",
		"status": "node --env-file=config.env --import tsx/esm src/status-check.ts && open web/index.html",
		"status-check": "node --env-file=config.env --import tsx/esm src/status-check.ts",
		"test": "vitest run",
		"coverage": "vitest run --coverage",
		"typecheck": "npx tsc --noEmit",
		"upgrade": "vrt deps-upgrade",
		"prepare": "git config core.hooksPath .githooks"
	},
	"dependencies": {
		"fast-xml-parser": "^5.7.2",
		"topojson-client": "^3.1.0"
	},
	"engines": {
		"node": ">=22"
	},
	"devDependencies": {
		"@types/geojson": "^7946.0.16",
		"@types/node": "^25.6.0",
		"@types/topojson-client": "^3.1.5",
		"@versatiles/release-tool": "^2.7.5",
		"@vitest/coverage-v8": "^4.1.5",
		"eslint": "^10.2.1",
		"prettier": "^3.8.3",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.0",
		"vitest": "^4.1.5"
	}
}