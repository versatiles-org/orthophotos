#!/bin/sh

# Check formatting of staged files. Prettier handles its own file-type detection
# and respects .prettierignore; --ignore-unknown silently skips other types.
STAGED=$(git diff --cached --name-only --diff-filter=ACM)
if [ -n "$STAGED" ]; then
  echo "Checking formatting..."
  echo "$STAGED" | xargs npx prettier --check --ignore-unknown 2>&1
  if [ $? -ne 0 ]; then
    echo ""
    echo "Formatting issues found. Run 'npm run format' to fix."
    exit 1
  fi
fi
