{
	"name": "orthophotos",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"check": "npm run format:check && npm run typecheck && npm run test",
		"format:check": "prettier --check 'src/**/*.ts'",
		"format": "prettier --write 'src/**/*.ts'",
		"run": "node --env-file=config.env --import tsx/esm src/run.ts",
		"server-prepare": "node --env-file=config.env --import tsx/esm src/server-prepare.ts",
		"server-start": "./server.sh",
		"server": "npm run server-prepare && npm run server-start",
		"status-check": "node --env-file=config.env --import tsx/esm src/status-check.ts",
		"test": "vitest run",
		"typecheck": "npx tsc --noEmit",
		"upgrade": "npm-check-updates -u && npm install"
	},
	"dependencies": {
		"topojson-client": "^3.1.0",
		"yaml": "^2.8.2"
	},
	"devDependencies": {
		"@types/geojson": "^7946.0.16",
		"@types/node": "^25.5.0",
		"@types/topojson-client": "^3.1.5",
		"prettier": "^3.8.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"npm-check-updates": "^19.6.3",
		"vitest": "^4.1.0"
	}
}
