{
	"name": "orthophotos",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"check": "npm run lint && npm run format:check && npm run typecheck && npm run test",
		"lint": "eslint 'src/**/*.ts'",
		"format:check": "prettier --check 'src/**/*.ts'",
		"format": "prettier --log-level warn --write 'src/**/*.ts'",
		"run": "node --env-file=config.env --import tsx/esm src/run.ts",
		"preview": "node --env-file=config.env --import tsx/esm src/preview.ts",
		"status-check": "node --env-file=config.env --import tsx/esm src/status-check.ts",
		"test": "vitest run",
		"coverage": "vitest run --coverage",
		"typecheck": "npx tsc --noEmit",
		"upgrade": "npm-check-updates -u && npm install"
	},
	"dependencies": {
		"fast-xml-parser": "^5.5.9",
		"topojson-client": "^3.1.0"
	},
	"engines": {
		"node": ">=22"
	},
	"devDependencies": {
		"@types/geojson": "^7946.0.16",
		"@types/node": "^25.5.0",
		"@types/topojson-client": "^3.1.5",
		"@vitest/coverage-v8": "^4.1.2",
		"eslint": "^10.1.0",
		"npm-check-updates": "^19.6.6",
		"prettier": "^3.8.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.57.2",
		"vitest": "^4.1.1"
	}
}
